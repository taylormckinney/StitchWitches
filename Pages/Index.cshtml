@page
@model IndexModel
@{
    ViewData["Title"] = "Stitch Witches";
}
@using StitchWitches.Models;
<img src="~/images/logo.png" class="img-responsive center-block" width="100%"/>
<div class="text-center">
    <h1 class="display-4">Welcome! We are Stitch Witches!</h1>
    <p>We create a variety of crocheted items, including stuffed animals, key chains and car charms, cardigans, and much more-- all hand made with love!</p>

</div>
<h3 class="text-center">Check out what we've been working on lately!</h3>
<div class="scrollContainer">
        @foreach (var item in Model.Items) 
    {
            <img src="~/images/@item.ImagePath" />
        }
   <div>
       <h4>Want to see more?</h4>
       <p>Check out our full gallery of projects below!</p>
        <a class="btn btn-default" asp-page="/InventoryItems/Index">See More</a>
   </div>
</div>


<div class="left">
    <p>Upcoming Markets</p>
</div>
<div class="right">
    <p>Contact Us</p>
</div>
<div class="container">
    <h3>Care Instructions</h3>

    <ul>
        <li>Strongly recommend hand-wash only</li>
        <li>Do not place in dryer, avoid excessive heat</li>
        <li>Roll out in towel to squeeze out excess water, then lay flat to dry</li>
    </ul>
</div>
