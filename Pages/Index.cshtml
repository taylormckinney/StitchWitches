@page
@model IndexModel
@{
    ViewData["Title"] = "Stitch Witches";
}
@using StitchWitches.Models;

<div class="text-center">
    <h1 class="display-4">Welcome! We are Stitch Witches!</h1>
    <p>We create a variety of crocheted items, including stuffed animals, key chains and car charms, cardigans, and much more-- all hand made with love!</p>

</div>
<h3 class="text-center">Check out what we've been working on lately!</h3>
<div class="scrollContainer">
        @foreach (var item in Model.Items) {
            <img src="~/images/@item.ImagePath" />
        }
   <div>
       <h4>Want to see more?</h4>
       <p>Check out our full gallery of projects below!</p>
        <a class="btn btn-primary" asp-page="/InventoryItems/Index">See More</a>
   </div>
</div>

<div class="left">
    <p>Upcoming Markets</p>
</div>
<div class="right">
    <p>Contact Us</p>
</div>

