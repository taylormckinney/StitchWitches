@page
@model StitchWitches.Pages.InventoryItems.EditModel
@using StitchWitches.Models

@{
    ViewData["Title"] = "Edit";
}

<h1>Edit</h1>

<h4>InventoryItem</h4>
<hr />
<div class="row">
    <div class="col-md-4">
        <form method="post" enctype="multipart/form-data">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <input type="hidden" asp-for="InventoryItem.Id" />
            <div class="form-group">

                <label asp-for="InventoryItem.Name" class="control-label"></label>
                <input asp-for="InventoryItem.Name" class="form-control" />
                <span asp-validation-for="InventoryItem.Name" class="text-danger"></span>
            </div>
            <div class="form-group">

                <label asp-for="InventoryItem.Description" class="control-label"></label>
                <input asp-for="InventoryItem.Description" class="form-control" />
                <span asp-validation-for="InventoryItem.Description" class="text-danger"></span>
            </div>
            <div class="form-group">

                <label asp-for="InventoryItem.Quantity" class="control-label"></label>
                <input asp-for="InventoryItem.Quantity" class="form-control" />
                <span asp-validation-for="InventoryItem.Quantity" class="text-danger"></span>
            </div>
            <div class="form-group">

                <label asp-for="InventoryItem.Price" class="control-label"></label>
                <input asp-for="InventoryItem.Price" class="form-control" />
                <span asp-validation-for="InventoryItem.Price" class="text-danger"></span>
            </div>
            <div class="form-group">

                <label asp-for="InventoryItem.Color" class="control-label"></label>
                <input asp-for="InventoryItem.Color" class="form-control" />
                <span asp-validation-for="InventoryItem.Color" class="text-danger"></span>
            </div>

            <div class="form-group">

                <label asp-for="InventoryItem.CreatedBy" class="control-label"></label>
                <select asp-for="InventoryItem.CreatedBy" asp-items="Html.GetEnumSelectList<MakerEnum>()" class="form-control"></select>
                <span asp-validation-for="InventoryItem.CreatedBy" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="InventoryItem.Category" class="control-label"></label>
                <select asp-for="InventoryItem.Category" asp-items="Html.GetEnumSelectList<CategoryEnum>()" class="form-control"></select>
                <span asp-validation-for="InventoryItem.Category" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="InventoryItem.SellCount" class="control-label"></label>
                <input asp-for="InventoryItem.SellCount" class="form-control" />
                <span asp-validation-for="InventoryItem.SellCount" class="text-danger"></span>
            </div>
            <div class="form-group">
                @if (Model != null && !String.IsNullOrEmpty(Model.InventoryItem.ImagePath))
                {
                    <label asp-for="ImgUpload">Current Image: @Model.InventoryItem.ImagePath</label>
                    <input asp-for="ExistingPath" type="hidden" value="@Model.InventoryItem.ImagePath" /> // Keeps track of existing image to avoid overposting
                }
                <label asp-for="ImgUpload"></label>
                <input asp-for="ImgUpload" type="file" />
            </div>
            <div class="form-group">
                <input type="submit" value="Save" class="btn btn-primary" />
            </div>
        </form>
       
    </div>
</div>

<div>
    <a asp-page="./Index">Back to List</a>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
