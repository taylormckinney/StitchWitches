@page
@model StitchWitches.Pages.Sales.DetailsModel
@using StitchWitches.Models

@{
    ViewData["Title"] = "Details";
}

<h1>Details</h1>

<div>
    <h4>Sale</h4>
    <hr />
    <dl class="row">
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.Sale.Market)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.Sale.Market)
        </dd>
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.Sale.SaleDate)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.Sale.SaleDate)
        </dd>
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.Sale.Total)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.Sale.Total)
        </dd>
        @*  <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.Sale.ItemsSold)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.Sale.ItemsSold)
        </dd> *@
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.Sale.PaymentMethod)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.Sale.PaymentMethod)
        </dd>
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.Sale.Notes)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.Sale.Notes)
        </dd>
    </dl>
</div>
<h2>@Html.DisplayNameFor(model => model.Sale.ItemsSold)</h2>
<div>
    <table class="table">
        <thead>
            <tr>
                <th>
                    @Html.DisplayNameFor(model => model.SoldItems[0].Name)
                </th>
                <th>
                    @Html.DisplayNameFor(model => model.SoldItems[0].Color)
                </th>
                <th>
                    @Html.DisplayNameFor(model => model.SoldItems[0].Price)
                </th>
                <th>
                    In Stock
                </th>
                <th>
                    @Html.DisplayNameFor(model => model.SoldItems[0].Category)
                </th>
            </tr>
        </thead>
        <tbody>
            @for (int i = 0; i < Model.SoldItems.Count; i++)
            {
                <tr>
                    <td>
                        @Html.DisplayFor(modelItem => Model.SoldItems[@i].Name)
                    </td>
                    <td>
                        @Html.DisplayFor(modelItem => Model.SoldItems[@i].Color)
                    </td>
                    <td>
                        @Html.DisplayFor(modelItem => Model.SoldItems[@i].Price)
                    </td>
                    <td>
                        @Html.DisplayFor(modelItem => Model.SoldItems[@i].Quantity)
                    </td>
                    <td>
                        @Html.DisplayFor(modelItem => Model.SoldItems[@i].Category)
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>
<div>
    <a asp-page="./Finalize" asp-route-id="@Model.Sale.Id">Edit</a> |
    <a asp-page="./Index">Back to List</a>
</div>
