@page
@model StitchWitches.Pages.Sales.FinalizeModel
@using StitchWitches.Models

@{
    ViewData["Title"] = "Finalize";
}

<h1>Finalize</h1>

<h4>Sale Details</h4>
<hr />
<dl class="row">
    <dt class="col-sm-2">
        @Html.DisplayNameFor(model => model.Sale.Id)
    </dt>
    <dd class="col-sm-10">
        @Html.DisplayFor(model => model.Sale.Id)
    </dd>
    <dt class="col-sm-2">
        @Html.DisplayNameFor(model => model.Sale.Market)
    </dt>
    <dd class="col-sm-10">
        @Html.DisplayFor(model => model.Sale.Market)
    </dd>
    <dt class="col-sm-2">
        Count of Items in this Order
    </dt>
    <dd class="col-sm-10">
        @Model.Sale.ItemsSold?.Count
    </dd>
</dl>
<h4>Items in Order</h4>
<button class="btn" type="button" onclick="EditSaleItems()">Edit Items</button>
<table class="table">
    <thead>
        <tr>
            <th>
                @Html.DisplayNameFor(model => model.SoldItems[0].Name)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.SoldItems[0].Price)
            </th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model.SoldItems)
        {
            <tr>
                <td>
                    @Html.DisplayFor(modelItem => item.Name)
                </td>
                <td>
                    @Html.DisplayFor(modelItem => item.Price)
                </td>
            </tr>
        }
    </tbody>
</table>
<h4>Confirm below?</h4>
<hr />
<div class="row">
    <div class="col-md-4">
        <form method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <input type="hidden" asp-for="Sale.Id" />

            <div class="form-group">

                <label asp-for="Sale.SaleDate" class="control-label"></label>
                <input asp-for="Sale.SaleDate" class="form-control" />
                <span asp-validation-for="Sale.SaleDate" class="text-danger"></span>
            </div>
            <div class="form-group">

                <label asp-for="Sale.Total" class="control-label"></label>
                <input asp-for="Sale.Total" class="form-control" />
                <span asp-validation-for="Sale.Total" class="text-danger"></span>
            </div>
            <div class="form-group form-check">

                <label class="form-check-label">
                    <select asp-for="Sale.PaymentMethod" asp-items="Html.GetEnumSelectList<PaymentEnum>()"></select>
                </label>
            </div>
            <div class="form-group">

                <label asp-for="Sale.Notes" class="control-label"></label>
                <input asp-for="Sale.Notes" class="form-control" />
                <span asp-validation-for="Sale.Notes" class="text-danger"></span>
            </div>
            <div class="form-group">
                <input type="submit" value="Save" class="btn btn-primary" />
            </div>
        </form>
    </div>
</div>

<div>
    <a asp-page="./Index">Back to List</a>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
