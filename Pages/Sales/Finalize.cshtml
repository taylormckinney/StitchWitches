@page
@model StitchWitches.Pages.Sales.FinalizeModel
@using StitchWitches.Models

@{
    ViewData["Title"] = "Finalize";
}

<h1>Finalize</h1>
<div class="container">
    <div class="row">


        
        <div id="SaleDetails" class="col-md">
            <h4>Sale Details</h4>
            <hr />
            <dl class="row">
                <dt class="col-sm-2">
                    @Html.DisplayNameFor(model => model.Sale.Id)
                </dt>
                <dd class="col-sm-10">
                    @Html.DisplayFor(model => model.Sale.Id)
                </dd>
                <dt class="col-sm-2">
                    @Html.DisplayNameFor(model => model.Sale.Market)
                </dt>
                <dd class="col-sm-10">
                    @Html.DisplayFor(model => model.Sale.Market)
                </dd>
                <dt class="col-sm-2">
                    Count of Items in this Order
                </dt>
                <dd class="col-sm-10">
                    @Model.Sale.ItemsSold?.Count
                </dd>
            </dl>
        </div>
        
        <div id="SaleItems" class="col-md">
            <h4>Items in Order</h4>
            <hr />
            
            <table class="table">
                <thead>
                    <tr>
                        <th>
                            @Html.DisplayNameFor(model => model.SoldItems[0].Name)
                        </th>
                        <th>
                            @Html.DisplayNameFor(model => model.SoldItems[0].Price)
                        </th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model.SoldItems)
                    {
                        <tr>
                            <td>
                                @Html.DisplayFor(modelItem => item.Name)
                            </td>
                            <td>
                                @Html.DisplayFor(modelItem => item.Price)
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
        <div id="EditItemsForm" style="display:none;" class="col-md">
            <p>test test this is a placeholder</p>
        </div>
    </div>
    <div class="row">
        <h4>Confirm below?</h4>
        <div id="ConfirmSaleForm">

            <hr />
            <div class="row">
                <div class="col-md-4">
                    <form method="post">
                        <div asp-validation-summary="ModelOnly" class="text-danger"></div>
                        <input type="hidden" asp-for="Sale.Id" />

                        <div class="form-group">

                            <label asp-for="Sale.SaleDate" class="control-label"></label>
                            <input asp-for="Sale.SaleDate" class="form-control" />
                            <span asp-validation-for="Sale.SaleDate" class="text-danger"></span>
                        </div>
                        <div class="form-group">

                            <label asp-for="Sale.Total" class="control-label"></label>
                            <input asp-for="Sale.Total" class="form-control" />
                            <span asp-validation-for="Sale.Total" class="text-danger"></span>
                        </div>
                        <div class="form-group">

                            <label asp-for="Sale.Market" class="control-label"></label>
                            <input asp-for="Sale.Market" class="form-control" />
                            <span asp-validation-for="Sale.Market" class="text-danger"></span>
                        </div>
                        <div class="form-group">

                            <label asp-for="Sale.Notes" class="control-label"></label>
                            <input asp-for="Sale.Notes" class="form-control" />
                            <span asp-validation-for="Sale.Notes" class="text-danger"></span>
                        </div>
                        <div class="form-group">

                            <label asp-for="Sale.PaymentMethod" class="control-label"></label>
                            <select asp-for="Sale.PaymentMethod" asp-items="Html.GetEnumSelectList<PaymentEnum>()" class="form-control form-select"></select>

                        </div>
                        <div class="form-group">
                            <input type="submit" value="Save" class="btn btn-primary" />
                            <a asp-page="SelectItems" asp-route-id="@Model.Sale.Id" asp-page-handler="Existing" class="btn btn-primary">Edit Order Items</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>
<div>
    <a asp-page="./Index">Back to List</a>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
