@page
@model StitchWitches.Pages.Sales.IndexModel

@{
    ViewData["Title"] = "Index";
}

<h1>Finalized Sales</h1>

<p>
    <a asp-page="Start">Start a new Sale</a>
</p>
<table class="table">
    <thead>
        <tr>
            <th>
                @Html.DisplayNameFor(model => model.Sale[0].Market)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Sale[0].SaleDate)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Sale[0].Total)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Sale[0].PaymentMethod)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Sale[0].Notes)
            </th>
            <th></th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model.Sale)
        {
            <tr>
                <td>
                    @Html.DisplayFor(modelItem => item.Market)
                </td>
                <td>
                    @Html.DisplayFor(modelItem => item.SaleDate)
                </td>
                <td>
                    @Html.DisplayFor(modelItem => item.Total)
                </td>
                <td>
                    @Html.DisplayFor(modelItem => item.PaymentMethod)
                </td>
                <td>
                    @Html.DisplayFor(modelItem => item.Notes)
                </td>
                <td>
                    <a asp-page="./Finalize" asp-route-id="@item.Id">Edit</a> |
                    <a asp-page="./Details" asp-route-id="@item.Id">Details</a> |
                    <a asp-page="./Delete" asp-route-id="@item.Id">Delete</a>
                </td>
            </tr>
        }
    </tbody>
</table>
